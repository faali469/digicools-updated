
-- Remove all furniture products and categories (not part of DigiCools digital marketplace)
delete from public.products
where category_id in (
  select id from public.categories
  where slug in (
    'sofas-seating', 'beds-bedroom', 'dining-kitchen',
    'storage-wardrobes', 'office-study', 'decor-lighting'
  )
);

delete from public.categories
where slug in (
  'sofas-seating', 'beds-bedroom', 'dining-kitchen',
  'storage-wardrobes', 'office-study', 'decor-lighting'
);

